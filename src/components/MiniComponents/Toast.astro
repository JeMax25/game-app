---
interface Props {
  title?: string;
  message: string;
  type?: 'success' | 'error';
}
const { title = "Success notification", message, type } = Astro.props;
---

<div 
  id="toast-alert" 
  class="fixed top-2 left-1/2 -translate-x-1/2 z-50 transition-all duration-500 ease-out -translate-y-40 opacity-0 w-[90%] max-w-md shadow-2xl"
>
  <div class="relative rounded-lg bg-gray-800 border border-white/10 p-4">
    <div class="flex items-start gap-3">
      <div class="shrink-0">
        <div class={`flex h-5 w-5 items-center justify-center rounded-full ${type === 'success' ? 'bg-green-500' : 'bg-red-500'}`}>

			{
				type === 'success' ? (
					<svg class="h-3 w-3 text-white" fill="currentColor" viewBox="0 0 20 20">
						<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
					</svg>
				) : (
					<svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20">
						<path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
					</svg>
				)
			}
        </div>
      </div>
      <div class="min-w-0 flex-1">
        <div class="mb-2 flex items-center gap-2">
          <svg class="h-4 w-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd" />
          </svg>
          <h3 class="font-medium text-white">{title}</h3>
        </div>
        <p class="mb-3 text-sm text-gray-300">{message}</p>
      </div>
      <button id="close-toast-btn" class="shrink-0 cursor-pointer text-gray-400 transition-colors hover:text-white">
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
        </svg>
      </button>
    </div>
  </div>
</div>

<script>
  setTimeout(() => {
    const toast = document.getElementById('toast-alert');
    const closeBtn = document.getElementById('close-toast-btn');
    
    if (toast) {
      // 1. Entrada: deslizamiento hacia abajo y opacidad total
      toast.classList.remove('-translate-y-40', 'opacity-0');
      toast.classList.add('translate-y-0', 'opacity-100');
      
      // 2. Temporizador para cerrar automáticamente en 5 segundos (5000ms)
      const autoCloseTimer = setTimeout(() => {
        closeToast();
      }, 5000);
      // 3. Cerrar inmediatamente si hace clic en la "X"
      closeBtn?.addEventListener('click', () => {
        clearTimeout(autoCloseTimer); // Cancelamos los 5s automáticos
        closeToast();
      });
      // Función común para cerrar con animación de salida
      function closeToast() {
        if (toast) {
          toast.classList.remove('translate-y-0', 'opacity-100');
          toast.classList.add('-translate-y-40', 'opacity-0');
          
          // Eliminar el elemento del DOM tras terminar la animación
          setTimeout(() => toast.remove(), 500);
        }
      }
    }
  }, 100);
</script>